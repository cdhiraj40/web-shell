{
  "name": "@solana-mobile/webshell-cli",
  "version": "0.1.0",
  "description": "Solana Mobile Web Shell is a Command Line Interface (CLI) that helps developers generate an Android app project that wraps an existing web app or website inside an Android WebView",
  "author": "Solana Mobile",
  "type": "module",
  "bin": {
    "webshell": "./bin/webshell.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solana-mobile/web-shell.git"
  },
  "homepage": "https://github.com/solana-mobile/web-shell#readme",
  "bugs": {
    "url": "https://github.com/solana-mobile/web-shell/issues"
  },
  "keywords": [
    "solana",
    "solana-mobile",
    "android",
    "webview",
    "mobile-wallet-adapter",
    "pwa",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "template",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.test.json",
    "cli": "tsx src/index.ts",
    "prepack": "npm run build",
    "test": "tsx --test ./test/*.test.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
